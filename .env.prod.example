# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://yourdomain.com

# ─── Database ─────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USERNAME=athena_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=athena_ai

# ─── JWT ──────────────────────────────────────────────────
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET=CHANGE_ME_run_command_above
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=CHANGE_ME_run_command_above_again
JWT_REFRESH_EXPIRATION=24h

# ─── OAuth: Google ────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ─── OAuth: GitHub ────────────────────────────────────────
# github.com → Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://yourdomain.com/api/auth/github/callback

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key